---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>For You</title>
  </head>

  <body>
    <main class="min-h-screen flex items-center justify-center bg-pink-50 overflow-hidden px-4">
      <section class="relative w-full max-w-md h-[620px] bg-white rounded-[32px] shadow-2xl flex flex-col items-center justify-center text-center border border-pink-100 overflow-hidden">
        
        <div class="absolute inset-0 pointer-events-none opacity-50">
          <span class="flower" style="top: 8%; left: 12%;">🌸</span>
          <span class="flower" style="top: 18%; left: 82%;">🌸</span>
          <span class="flower" style="top: 35%; left: 6%;">🌸</span>
          <span class="flower" style="top: 62%; left: 88%;">🌸</span>
          <span class="flower" style="top: 78%; left: 18%;">🌸</span>
          <span class="flower" style="top: 86%; left: 72%;">🌸</span>
          <span class="flower" style="top: 48%; left: 45%;">🌸</span>
        </div>

        <div id="question" class="relative z-10 flex flex-col items-center">
          <div class="w-36 h-36 rounded-3xl overflow-hidden shadow-md mb-10 bg-pink-100">
            <img
              src="/cute.jpg"
              alt="cute"
              class="w-full h-full object-cover"
            />
          </div>

          <h1 class="text-3xl font-bold text-pink-950 leading-tight px-6">
            🌸 Will you go on a date with me? 🌸
          </h1>

          <button
            id="yesBtn"
            class="mt-12 px-10 py-4 bg-pink-400 hover:bg-pink-500 text-white rounded-full font-bold shadow-lg transition active:scale-95"
          >
            YES 💕
          </button>

          <button
            id="noBtn"
            class="absolute px-8 py-3 bg-purple-100 text-purple-700 rounded-full font-semibold shadow-md transition-all duration-300"
            style="top: 58%; left: 58%;"
          >
            no... 🐒
          </button>
        </div>

        <div id="accepted" class="relative z-10 hidden px-6">
          <div class="text-7xl mb-6">💖</div>

          <h2 class="text-4xl font-bold text-pink-600 mb-4">
            Yaaay!
          </h2>

          <p class="text-xl text-pink-950">
            I knew you would say yes 😌💕
          </p>

          <div class="mt-10 text-4xl animate-bounce">
            🐱 🌸 💗
          </div>
        </div>
      </section>
    </main>

    <script>
      const noBtn = document.getElementById("noBtn");
      const yesBtn = document.getElementById("yesBtn");
      const question = document.getElementById("question");
      const accepted = document.getElementById("accepted");

      function moveNoButton() {
        const top = Math.floor(Math.random() * 60) + 15;
        const left = Math.floor(Math.random() * 60) + 15;

        noBtn.style.top = `${top}%`;
        noBtn.style.left = `${left}%`;
      }

      noBtn.addEventListener("mouseenter", moveNoButton);
      noBtn.addEventListener("click", moveNoButton);
      noBtn.addEventListener("touchstart", moveNoButton);

      yesBtn.addEventListener("click", () => {
        question.classList.add("hidden");
        accepted.classList.remove("hidden");
      });
    </script>

    <style>
      .flower {
        position: absolute;
        font-size: 24px;
        animation: float 3s ease-in-out infinite;
      }

      @keyframes float {
        0%, 100% {
          transform: translateY(0);
        }

        50% {
          transform: translateY(-10px);
        }
      }
    </style>
  </body>
</html>
